[default language_features=MAXIMUM]

# Group rows not supported.
FROM TestTable
|> AGGREGATE ARRAY(WITH group_rows() AS GROUP ROWS
                   FROM group_rows()
                   |> SELECT key)
--
ERROR: GROUP ROWS is not supported. [at 3:41]
|> AGGREGATE ARRAY(WITH group_rows() AS GROUP ROWS
                                        ^
==

[default language_features=MAXIMUM,+WITH_GROUP_ROWS]
[default no_run_sqlbuilder]
# TODO: b/430036320 - Enable SQL builder once it supports GROUP ROWS.

# Group rows in PIPE WITH operator fails.
FROM TestTable
|> WITH group_rows() AS GROUP ROWS
|> SELECT key
--
ERROR: GROUP ROWS not supported in Pipe WITH operator [at 5:9]
|> WITH group_rows() AS GROUP ROWS
        ^
==

# Multiple group rows entries fail.
FROM TestTable
|> AGGREGATE ARRAY(WITH
                     group_rows1() AS GROUP ROWS,
                     group_rows2() AS GROUP ROWS
                   FROM group_rows1()
                   |> SELECT key)
--
ERROR: Cannot have more than one GROUP ROWS alias in a with clause [at 4:22]
                     group_rows2() AS GROUP ROWS
                     ^
==

# Group rows entry not being first fails.
FROM TestTable
|> AGGREGATE ARRAY(WITH
                     t AS (SELECT 1, 2),
                     group_rows() AS GROUP ROWS
                   FROM group_rows()
                   |> SELECT key)
--
ERROR: GROUP ROWS must be the first entry in a WITH clause [at 4:22]
                     group_rows() AS GROUP ROWS
                     ^
==

# Calling group rows TVF with an argument doesn't work.
FROM TestTable
|> AGGREGATE ARRAY(WITH group_rows() AS GROUP ROWS
                   SELECT * FROM group_rows(1))
--
ERROR: Cannot call group rows TVF with arguments. [at 3:34]
                   SELECT * FROM group_rows(1))
                                 ^
==

# Calling group rows TVF with an implicit argument doesn't work.
FROM TestTable
|> AGGREGATE ARRAY(WITH group_rows() AS GROUP ROWS
                   FROM MultipleColumns
                   |> CALL group_rows())
--
ERROR: Cannot call group rows TVF with arguments. [at 4:28]
                   |> CALL group_rows())
                           ^
==

# TODO: b/430036320 - Add more tests once GroupRowsScan is moved into aggregate
# scan. AGGREGATE ARRAY fails if it contains a non-aggregate expression.
FROM TestTable
|> AGGREGATE ARRAY(WITH group_rows() AS GROUP ROWS
                   FROM group_rows()
                   |> SELECT key)
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#10 AS `$col1` [ARRAY<INT32>]
+-query=
  +-AggregateScan
    +-column_list=[$expr_subquery.$group_rows_subquery#10]
    +-input_scan=
    | +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2])
    +-aggregate_list=
      +-$group_rows_subquery#10 :=
        +-SubqueryExpr
          +-type=ARRAY<INT32>
          +-subquery_type=ARRAY
          +-subquery=
            +-ProjectScan
              +-column_list=[TestTable.key#7]
              +-input_scan=
                +-GroupRowsScan
                  +-column_list=[TestTable.key#7]
                  +-input_column_list=
                    +-key#7 := ColumnRef(type=INT32, column=TestTable.key#1)
                    +-TestEnum#8 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
                    +-KitchenSink#9 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
==

# Group rows TVF only sees most recent table alias schema.
FROM TestTable t1
|> AS t2
|> AGGREGATE ARRAY(WITH group_rows() AS GROUP ROWS
                   FROM group_rows()
                   |> SELECT {{t1|t2}}.key)
--
ALTERNATION GROUP: t1
--
ERROR: Unrecognized name: t1 [at 5:30]
                   |> SELECT t1.key)
                             ^
--
ALTERNATION GROUP: t2
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#10 AS `$col1` [ARRAY<INT32>]
+-query=
  +-AggregateScan
    +-column_list=[$expr_subquery.$group_rows_subquery#10]
    +-input_scan=
    | +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2], alias="t1")
    +-aggregate_list=
      +-$group_rows_subquery#10 :=
        +-SubqueryExpr
          +-type=ARRAY<INT32>
          +-subquery_type=ARRAY
          +-subquery=
            +-ProjectScan
              +-column_list=[TestTable.key#7]
              +-input_scan=
                +-GroupRowsScan
                  +-column_list=[TestTable.key#7]
                  +-input_column_list=
                    +-key#7 := ColumnRef(type=INT32, column=TestTable.key#1)
                    +-TestEnum#8 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
                    +-KitchenSink#9 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
==

