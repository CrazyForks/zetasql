                  +-input_column_list=
                    +-key#8 := ColumnRef(type=INT32, column=TestTable.key#1)
                    +-TestEnum#9 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
