# Sugar syntax on query containing WITH.
FROM TestTable
|> AGGREGATE ARRAY(
     WITH t AS (SELECT 1 AS x)
     FROM GROUP ROWS
     |> SELECT AS STRUCT key, (SELECT x FROM t)
   )
--
QueryStmt
+-output_column_list=
| +-$expr_subquery.$group_rows_subquery#18 AS `$col1` [ARRAY<STRUCT<key INT32, INT64>>]
+-query=
  +-AggregateScan
    +-column_list=[$expr_subquery.$group_rows_subquery#18]
    +-input_scan=
    | +-TableScan(column_list=TestTable.[key#1, TestEnum#2, KitchenSink#3], table=TestTable, column_index_list=[0, 1, 2])
    +-aggregate_list=
      +-$group_rows_subquery#18 :=
        +-SubqueryExpr
          +-type=ARRAY<STRUCT<key INT32, INT64>>
          +-subquery_type=ARRAY
          +-subquery=
            +-WithScan
              +-column_list=[$make_struct.$struct#17]
              +-with_entry_list=
              | +-WithEntry
              |   +-with_query_name="t_1"
              |   +-with_subquery=
              |     +-ProjectScan
              |       +-column_list=[t.x#11]
              |       +-expr_list=
              |       | +-x#11 := Literal(type=INT64, value=1)
              |       +-input_scan=
              |         +-SingleRowScan
              +-query=
                +-ProjectScan
                  +-column_list=[$make_struct.$struct#17]
                  +-expr_list=
                  | +-$struct#17 :=
                  |   +-MakeStruct
                  |     +-type=STRUCT<key INT32, INT64>
                  |     +-field_list=
                  |       +-ColumnRef(type=INT32, column=TestTable.key#12)
                  |       +-ColumnRef(type=INT64, column=$pipe_select.$col2#16)
                  +-input_scan=
                    +-ProjectScan
                      +-column_list=[TestTable.key#12, $pipe_select.$col2#16]
                      +-expr_list=
                      | +-$col2#16 :=
                      |   +-SubqueryExpr
                      |     +-type=INT64
                      |     +-subquery_type=SCALAR
                      |     +-subquery=
                      |       +-ProjectScan
                      |         +-column_list=[t_1.x#15]
                      |         +-input_scan=
                      |           +-WithRefScan(column_list=[t_1.x#15], with_query_name="t_1")
                      +-input_scan=
                        +-GroupRowsScan
                          +-column_list=[TestTable.key#12]
                          +-input_column_list=
                            +-key#12 := ColumnRef(type=INT32, column=TestTable.key#1)
                            +-TestEnum#13 := ColumnRef(type=ENUM<googlesql_test.TestEnum>, column=TestTable.TestEnum#2)
                            +-KitchenSink#14 := ColumnRef(type=PROTO<googlesql_test.KitchenSinkPB>, column=TestTable.KitchenSink#3)
==

