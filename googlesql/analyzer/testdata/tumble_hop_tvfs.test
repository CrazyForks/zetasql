# Test case using a scalar subquery as the 'window_size' argument.
# It uses the catalog tables TimeSeries and WindowParams defined above.
SELECT * FROM TUMBLE(
  TABLE TimeSeries,
  'event_time',
  (SELECT window_size FROM WindowParams WHERE id = 1)
);
