# Test case verifying that complex expressions (e.g., CASE statements) are accepted as arguments.
SELECT * FROM TUMBLE(
  TABLE TimeSeries,
  'event_time',
  CASE WHEN TRUE THEN INTERVAL '10' MINUTE ELSE INTERVAL '1' HOUR END
);
