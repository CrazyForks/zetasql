# Validates that a dropped column is passed through and marked as (passthrough) for TUMBLE.
FROM (SELECT 1 as a, TIMESTAMP '2026-01-01 00:00:00+00' AS ts_col) AS rv
|> DROP a
|> CALL tumble("ts_col", INTERVAL 1 DAY)
|> STATIC_DESCRIBE;
--
