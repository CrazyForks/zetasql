        | | |   +-expr_list=
        | | |   | +-a#1 := Literal(type=INT64, value=1)
        | | |   | +-ts_col#2 := Literal(type=TIMESTAMP, value=2026-01-01 00:00:00+00, has_explicit_type=TRUE)
