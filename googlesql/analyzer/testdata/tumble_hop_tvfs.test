        +-signature=(TABLE<ts_col TIMESTAMP, a INT64 (passthrough)>, literal STRING, INTERVAL, literal TIMESTAMP) -> TABLE<ts_col TIMESTAMP, a INT64 (passthrough), WINDOW_START TIMESTAMP, WINDOW_END TIMESTAMP>
        +-argument_list=
        | +-FunctionArgument
