# Test case using scalar subqueries for window parameters.
SELECT * FROM HOP(
  TABLE TimeSeries,
  'event_time',
  (SELECT window_size FROM WindowParams WHERE id = 1),
  (SELECT step_size FROM WindowParams WHERE id = 1)
);
