# Test case where input table has conflicting and mixed-case window columns for HOP.
# The rewriter should drop all of them (case-insensitively).
WITH t AS (
  SELECT TIMESTAMP '2025-01-01' AS ts_col, 2 AS winDow_start, 3 AS Window_End, 4 AS WINDOW_START, 5 AS WINDOW_END
)
SELECT * FROM HOP(TABLE t, 'ts_col', INTERVAL '1' DAY, INTERVAL '1' HOUR);
