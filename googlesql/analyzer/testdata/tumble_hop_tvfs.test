# Test case verifying HOP accepts conditional expressions (CASE).
SELECT * FROM HOP(
  TABLE TimeSeries,
  'event_time',
  CASE WHEN 1 > 0 THEN INTERVAL '1' HOUR ELSE INTERVAL '2' HOUR END,
  CASE WHEN 2 > 1 THEN INTERVAL '30' MINUTE ELSE INTERVAL '45' MINUTE END
);
