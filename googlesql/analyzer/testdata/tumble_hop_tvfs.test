| +-hop.WINDOW_START#4 AS WINDOW_START [TIMESTAMP]
| +-hop.WINDOW_END#5 AS WINDOW_END [TIMESTAMP]
+-query=
  +-ProjectScan
    +-column_list=hop.[ts_col#3, WINDOW_START#4, WINDOW_END#5]
    +-input_scan=
      +-TVFScan
        +-column_list=hop.[ts_col#3, WINDOW_START#4, WINDOW_END#5]
        +-tvf=GoogleSQL:hop((ANY TABLE table_expr, STRING timestamp_column, INTERVAL window_size, INTERVAL step_size, optional TIMESTAMP {default_value: 1970-01-01 00:00:00+00} origin) -> ANY TABLE; (ANY TABLE table_expr, INTERVAL window_size, INTERVAL step_size, optional TIMESTAMP {default_value: 1970-01-01 00:00:00+00} origin) -> ANY TABLE)
