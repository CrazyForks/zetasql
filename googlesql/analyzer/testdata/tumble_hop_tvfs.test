# Test case verifying correlated references in HOP arguments are unsupported.
SELECT *
FROM WindowParams
CROSS JOIN LATERAL HOP(
  TABLE TimeSeries,
  'event_time',
  INTERVAL '1' HOUR,
  WindowParams.step_size
);
