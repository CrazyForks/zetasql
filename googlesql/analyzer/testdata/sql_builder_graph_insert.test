# Declaration: anonymous node variable in an INSERT pattern
GRAPH aml
INSERT (:Person {name: "John", id: 1})
--
GeneralizedQueryStmt
+-query=
  +-GraphTableScan
    +-property_graph=aml
    +-input_scan=
      +-GraphLinearScan
        +-scan_list=
          +-GraphLinearScan
            +-scan_list=
              +-FinishScan
                +-input_scan=
                  +-GraphInsertScan
                    +-input_scan=
                    | +-SingleRowScan
                    +-insert_node_list=
                    | +-$insert_node#1 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     | | +-property_name="name"
                    |     | | +-property=name(STRING)
                    |     | | +-property_value=
                    |     | |   +-Literal(type=STRING, value="John")
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="id"
                    |     |   +-property=id(INT64)
                    |     |   +-property_value=
                    |     |     +-Literal(type=INT64, value=1)
                    |     +-label_list=
                    |     | +-GraphLabel(label=aml.Person)
                    |     +-element_table=Person
                    +-path_element_list=[$element_table.$insert_node#1]

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
GRAPH aml
INSERT
  (IS Person { name : "John", id : 1 });

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
GRAPH aml
INSERT
  (IS Person { name : "John", id : 1 });
==

# Declaration: anonymous edge variables in an INSERT pattern
GRAPH aml
INSERT (p:Person {id: 1})-[:PersonOwnAccount]->(a:Account {id: 2})
--
GeneralizedQueryStmt
+-query=
  +-GraphTableScan
    +-property_graph=aml
    +-input_scan=
      +-GraphLinearScan
        +-scan_list=
          +-GraphLinearScan
            +-scan_list=
              +-FinishScan
                +-input_scan=
                  +-GraphInsertScan
                    +-column_list=$element_table.[p#1, a#2]
                    +-input_scan=
                    | +-SingleRowScan
                    +-insert_node_list=
                    | +-p#1 :=
                    | | +-GraphInsertElement
                    | |   +-type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>
                    | |   +-property_list=
                    | |   | +-GraphDMLPropertyItem
                    | |   |   +-property_name="id"
                    | |   |   +-property=id(INT64)
                    | |   |   +-property_value=
                    | |   |     +-Literal(type=INT64, value=1)
                    | |   +-label_list=
                    | |   | +-GraphLabel(label=aml.Person)
                    | |   +-element_table=Person
                    | +-a#2 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml)<balance UINT64, id INT64>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="id"
                    |     |   +-property=id(INT64)
                    |     |   +-property_value=
                    |     |     +-Literal(type=INT64, value=2)
                    |     +-label_list=
                    |     | +-GraphLabel(label=aml.Account)
                    |     +-element_table=Account
                    +-insert_edge_list=
                    | +-$insert_edge#3 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_EDGE(aml)<accountId INT64, personId INT64>
                    |     +-label_list=
                    |     | +-GraphLabel(label=aml.PersonOwnAccount)
                    |     +-source_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.p#1)
                    |     +-dest_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml)<balance UINT64, id INT64>, column=$element_table.a#2)
                    |     +-element_table=PersonOwnAccount
                    +-path_element_list=$element_table.[p#1, $insert_edge#3, a#2]

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
GRAPH aml
INSERT
  (a_1 IS Person { id : 1 }) -[IS PersonOwnAccount]-> (a_2 IS Account { id : 2 });

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
GRAPH aml
INSERT
  (a_1 IS Person { id : 1 }) -[IS PersonOwnAccount]-> (a_2 IS Account { id : 2 });
==

# Reference: Declaring a node variable and referencing it in the same INSERT but
# in different patterns is OK.
GRAPH aml
INSERT (p:Person {name: "A"}), (p)
--
GeneralizedQueryStmt
+-query=
  +-GraphTableScan
    +-property_graph=aml
    +-input_scan=
      +-GraphLinearScan
        +-scan_list=
          +-GraphLinearScan
            +-scan_list=
              +-FinishScan
                +-input_scan=
                  +-GraphInsertScan
                    +-input_scan=
                    | +-SingleRowScan
                    +-insert_node_list=
                    | +-p#1 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="name"
                    |     |   +-property=name(STRING)
                    |     |   +-property_value=
                    |     |     +-Literal(type=STRING, value="A")
                    |     +-label_list=
                    |     | +-GraphLabel(label=aml.Person)
                    |     +-element_table=Person
                    +-path_element_list=$element_table.[p#1, p#1]

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
