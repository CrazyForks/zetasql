[default language_features=NONE,+SQL_GRAPH,+SQL_GRAPH_ADVANCED_QUERY,+SQL_GRAPH_RETURN_EXTENSIONS,+SQL_GRAPH_TERMINAL_INSERT]
[default no_test_extract_table_names]
[default run_sqlbuilder]
[default show_sqlbuilder_output]

# Labels: Label conjunction (&) works
GRAPH aml
INSERT (n:Person & HasId {name: "John", id: 1})
--
GeneralizedQueryStmt
+-query=
  +-GraphTableScan
    +-property_graph=aml
    +-input_scan=
      +-GraphLinearScan
        +-scan_list=
          +-GraphLinearScan
            +-scan_list=
              +-FinishScan
                +-input_scan=
                  +-GraphInsertScan
                    +-input_scan=
                    | +-SingleRowScan
                    +-insert_node_list=
                    | +-n#1 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     | | +-property_name="name"
                    |     | | +-property=name(STRING)
                    |     | | +-property_value=
                    |     | |   +-Literal(type=STRING, value="John")
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="id"
                    |     |   +-property=id(INT64)
                    |     |   +-property_value=
                    |     |     +-Literal(type=INT64, value=1)
                    |     +-label_list=
                    |     | +-GraphLabel(label=aml.Person)
                    |     | +-GraphLabel(label=aml.HasId)
                    |     +-element_table=Person
                    +-path_element_list=[$element_table.n#1]

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
GRAPH aml
INSERT
  (a_1 IS Person & HasId { name : "John", id : 1 });

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
GRAPH aml
INSERT
  (a_1 IS Person & HasId { name : "John", id : 1 });
==

