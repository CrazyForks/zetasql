# Reference: Declaring a node variable and referencing it multiple times in the
# same INSERT statement (across different patterns and inside patterns) is OK.
GRAPH aml
INSERT (p:Person {id: 1})-[e1:PersonOwnAccount]->(a1:Account {id: 100}), (p)-[e2:PersonOwnAccount]->(a2:Account {id: 200})
--
GeneralizedQueryStmt
+-query=
  +-GraphTableScan
    +-property_graph=aml
    +-input_scan=
      +-GraphLinearScan
        +-scan_list=
          +-GraphLinearScan
            +-scan_list=
              +-FinishScan
                +-input_scan=
                  +-GraphInsertScan
                    +-column_list=$element_table.[p#1, a1#2, a2#4]
                    +-input_scan=
                    | +-SingleRowScan
                    +-insert_node_list=
                    | +-p#1 :=
                    | | +-GraphInsertElement
                    | |   +-type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>
                    | |   +-property_list=
                    | |   | +-GraphDMLPropertyItem
                    | |   |   +-property_name="id"
                    | |   |   +-property=id(INT64)
                    | |   |   +-property_value=
                    | |   |     +-Literal(type=INT64, value=1)
                    | |   +-label_list=
                    | |   | +-GraphLabel(label=aml.Person)
                    | |   +-element_table=Person
                    | +-a1#2 :=
                    | | +-GraphInsertElement
                    | |   +-type=GRAPH_NODE(aml)<balance UINT64, id INT64>
                    | |   +-property_list=
                    | |   | +-GraphDMLPropertyItem
                    | |   |   +-property_name="id"
                    | |   |   +-property=id(INT64)
                    | |   |   +-property_value=
                    | |   |     +-Literal(type=INT64, value=100)
                    | |   +-label_list=
                    | |   | +-GraphLabel(label=aml.Account)
                    | |   +-element_table=Account
                    | +-a2#4 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml)<balance UINT64, id INT64>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="id"
                    |     |   +-property=id(INT64)
                    |     |   +-property_value=
                    |     |     +-Literal(type=INT64, value=200)
                    |     +-label_list=
                    |     | +-GraphLabel(label=aml.Account)
                    |     +-element_table=Account
                    +-insert_edge_list=
                    | +-e1#3 :=
                    | | +-GraphInsertElement
                    | |   +-type=GRAPH_EDGE(aml)<accountId INT64, personId INT64>
                    | |   +-label_list=
                    | |   | +-GraphLabel(label=aml.PersonOwnAccount)
                    | |   +-source_node=
                    | |   | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.p#1)
                    | |   +-dest_node=
                    | |   | +-ColumnRef(type=GRAPH_NODE(aml)<balance UINT64, id INT64>, column=$element_table.a1#2)
                    | |   +-element_table=PersonOwnAccount
                    | +-e2#5 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_EDGE(aml)<accountId INT64, personId INT64>
                    |     +-label_list=
                    |     | +-GraphLabel(label=aml.PersonOwnAccount)
                    |     +-source_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.p#1)
                    |     +-dest_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml)<balance UINT64, id INT64>, column=$element_table.a2#4)
                    |     +-element_table=PersonOwnAccount
                    +-path_element_list=$element_table.[p#1, e1#3, a1#2, p#1, e2#5, a2#4]

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
GRAPH aml
INSERT
  (a_1 IS Person { id : 1 }) -[a_2 IS PersonOwnAccount]-> (a_3 IS Account { id : 100 }), (a_1) -[a_4 IS PersonOwnAccount]->
  (a_5 IS Account { id : 200 });

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
GRAPH aml
INSERT
  (a_1 IS Person { id : 1 }) -[a_2 IS PersonOwnAccount]-> (a_3 IS Account { id : 100 }), (a_1) -[a_4 IS PersonOwnAccount]->
  (a_5 IS Account { id : 200 });
