# Success: Valid node insert
GRAPH aml
INSERT (n:Person {name: "John"})
--
GeneralizedQueryStmt
+-query=
  +-GraphTableScan
    +-property_graph=aml
    +-input_scan=
      +-GraphLinearScan
        +-scan_list=
          +-GraphLinearScan
            +-scan_list=
              +-FinishScan
                +-input_scan=
                  +-GraphInsertScan
                    +-input_scan=
                    | +-SingleRowScan
                    +-insert_node_list=
                    | +-n#1 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="name"
                    |     |   +-property=name(STRING)
                    |     |   +-property_value=
                    |     |     +-Literal(type=STRING, value="John")
                    |     +-label_list=
                    |     | +-GraphLabel(label=aml.Person)
                    |     +-element_table=Person
                    +-path_element_list=[$element_table.n#1]

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
GRAPH aml
INSERT
  (a_1 IS Person { name : "John" });

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
GRAPH aml
INSERT
  (a_1 IS Person { name : "John" });
==

# RETURN after INSERT is supported.
GRAPH aml
INSERT (n:Person {name: "John"})
RETURN n.name AS name
--
GeneralizedQueryStmt
+-output_schema=
| +-OutputSchema
|   +-output_column_list=
|     +-$graph_table.name#2 AS name [STRING]
+-query=
  +-GraphTableScan
    +-column_list=[$graph_table.name#2]
    +-property_graph=aml
    +-input_scan=
      +-GraphLinearScan
        +-column_list=[$graph_table.name#2]
        +-scan_list=
          +-GraphLinearScan
            +-column_list=[$graph_table.name#2]
            +-scan_list=
              +-GraphInsertScan
              | +-column_list=[$element_table.n#1]
              | +-input_scan=
              | | +-SingleRowScan
              | +-insert_node_list=
              | | +-n#1 :=
              | |   +-GraphInsertElement
              | |     +-type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>
              | |     +-property_list=
              | |     | +-GraphDMLPropertyItem
              | |     |   +-property_name="name"
              | |     |   +-property=name(STRING)
              | |     |   +-property_value=
              | |     |     +-Literal(type=STRING, value="John")
              | |     +-label_list=
              | |     | +-GraphLabel(label=aml.Person)
              | |     +-element_table=Person
              | +-path_element_list=[$element_table.n#1]
              +-ProjectScan
                +-column_list=[$graph_table.name#2]
                +-expr_list=
                | +-name#2 :=
                |   +-GraphGetElementProperty
                |     +-type=STRING
                |     +-expr=
                |     | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.n#1)
                |     +-property=name(STRING)
                +-input_scan=
                  +-GraphRefScan(column_list=[$element_table.n#1])

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
GRAPH aml
INSERT
  (a_1 IS Person { name : "John" })
RETURN
  a_1.name AS a_2;

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
GRAPH aml
INSERT
  (a_1 IS Person { name : "John" })
RETURN
  a_1.name AS a_2;
==

# Set op before INSERT is allowed.
GRAPH aml
MATCH (n:Account)
RETURN n
UNION all
MATCH (n:Account)
RETURN n
NEXT
INSERT (p:Person {id: 1})-[e:PersonOwnAccount]->(n)
--
GeneralizedQueryStmt
+-query=
  +-GraphTableScan
    +-property_graph=aml
    +-input_scan=
      +-GraphLinearScan
        +-scan_list=
          +-SetOperationScan
          | +-column_list=[$graph_set_op.n#5]
          | +-op_type=UNION_ALL
          | +-input_item_list=
          | | +-SetOperationItem
          | | | +-scan=
          | | | | +-GraphLinearScan
          | | | |   +-column_list=[$graph_table.n#2]
          | | | |   +-scan_list=
          | | | |     +-GraphScan
          | | | |     | +-column_list=[$element_table.n#1]
          | | | |     | +-input_scan_list=
          | | | |     | | +-GraphPathScan
          | | | |     | |   +-column_list=[$element_table.n#1]
          | | | |     | |   +-input_scan_list=
          | | | |     | |   | +-GraphNodeScan
          | | | |     | |   |   +-column_list=[$element_table.n#1]
          | | | |     | |   |   +-label_expr=
          | | | |     | |   |   | +-GraphLabel(parse_location=19-26, label=aml.Account)
          | | | |     | |   |   +-target_element_table_list=[aml.Account]
          | | | |     | |   +-head=$element_table.n#1
          | | | |     | |   +-tail=$element_table.n#1
          | | | |     | +-input_scan=
          | | | |     |   +-SingleRowScan
          | | | |     +-ProjectScan
          | | | |       +-column_list=[$graph_table.n#2]
          | | | |       +-expr_list=
          | | | |       | +-n#2 := ColumnRef(type=GRAPH_NODE(aml)<balance UINT64, id INT64>, column=$element_table.n#1)
          | | | |       +-input_scan=
          | | | |         +-GraphRefScan(column_list=[$element_table.n#1])
          | | | +-output_column_list=[$graph_table.n#2]
          | | +-SetOperationItem
          | |   +-scan=
          | |   | +-GraphLinearScan
          | |   |   +-column_list=[$graph_table.n#4]
          | |   |   +-scan_list=
          | |   |     +-GraphScan
          | |   |     | +-column_list=[$element_table.n#3]
          | |   |     | +-input_scan_list=
          | |   |     | | +-GraphPathScan
          | |   |     | |   +-column_list=[$element_table.n#3]
          | |   |     | |   +-input_scan_list=
          | |   |     | |   | +-GraphNodeScan
          | |   |     | |   |   +-column_list=[$element_table.n#3]
          | |   |     | |   |   +-label_expr=
          | |   |     | |   |   | +-GraphLabel(parse_location=56-63, label=aml.Account)
          | |   |     | |   |   +-target_element_table_list=[aml.Account]
          | |   |     | |   +-head=$element_table.n#3
          | |   |     | |   +-tail=$element_table.n#3
          | |   |     | +-input_scan=
          | |   |     |   +-SingleRowScan
          | |   |     +-ProjectScan
          | |   |       +-column_list=[$graph_table.n#4]
          | |   |       +-expr_list=
          | |   |       | +-n#4 := ColumnRef(type=GRAPH_NODE(aml)<balance UINT64, id INT64>, column=$element_table.n#3)
          | |   |       +-input_scan=
          | |   |         +-GraphRefScan(column_list=[$element_table.n#3])
          | |   +-output_column_list=[$graph_table.n#4]
          | +-column_match_mode=CORRESPONDING
          +-GraphLinearScan
            +-scan_list=
              +-FinishScan
                +-input_scan=
                  +-GraphInsertScan
                    +-column_list=[$graph_set_op.n#5, $element_table.p#6]
                    +-input_scan=
                    | +-GraphRefScan(column_list=[$graph_set_op.n#5])
                    +-insert_node_list=
                    | +-p#6 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>
                    |     +-property_list=
                    |     | +-GraphDMLPropertyItem
                    |     |   +-property_name="id"
                    |     |   +-property=id(INT64)
                    |     |   +-property_value=
                    |     |     +-Literal(type=INT64, value=1)
                    |     +-label_list=
                    |     | +-GraphLabel(label=aml.Person)
                    |     +-element_table=Person
                    +-insert_edge_list=
                    | +-e#7 :=
                    |   +-GraphInsertElement
                    |     +-type=GRAPH_EDGE(aml)<accountId INT64, personId INT64>
                    |     +-label_list=
                    |     | +-GraphLabel(label=aml.PersonOwnAccount)
                    |     +-source_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml)<age UINT32, birthday DATE, data BYTES, id INT64, name STRING>, column=$element_table.p#6)
                    |     +-dest_node=
                    |     | +-ColumnRef(type=GRAPH_NODE(aml)<balance UINT64, id INT64>, column=$graph_set_op.n#5)
                    |     +-element_table=PersonOwnAccount
                    +-path_element_list=[$element_table.p#6, $element_table.e#7, $graph_set_op.n#5]

[SQLBUILDER_TARGET_SYNTAX_MODE standard]
[SQLBUILDER_OUTPUT]
GRAPH aml
MATCH
  (a_2 IS Account)
RETURN
  a_2 AS a_1
UNION ALL
MATCH
  (a_3 IS Account)
RETURN
  a_3 AS a_1
NEXT
INSERT
  (a_4 IS Person { id : 1 }) -[a_5 IS PersonOwnAccount]-> (a_1);

[SQLBUILDER_TARGET_SYNTAX_MODE pipe]
[SQLBUILDER_OUTPUT]
GRAPH aml
MATCH
  (a_2 IS Account)
RETURN
  a_2 AS a_1
UNION ALL
MATCH
  (a_3 IS Account)
RETURN
  a_3 AS a_1
NEXT
INSERT
  (a_4 IS Person { id : 1 }) -[a_5 IS PersonOwnAccount]-> (a_1);
==

# Aggregation before INSERT is allowed.
GRAPH aml
MATCH (n:Person)
WITH n, count(*) as cnt
INSERT (n)-[e:PersonOwnAccount]->(a:Account {id: 2})
--
GeneralizedQueryStmt
+-query=
  +-GraphTableScan
    +-property_graph=aml
    +-input_scan=
      +-GraphLinearScan
        +-scan_list=
          +-GraphLinearScan
            +-scan_list=
              +-GraphScan
              | +-column_list=[$element_table.n#1]
              | +-input_scan_list=
              | | +-GraphPathScan
              | |   +-column_list=[$element_table.n#1]
              | |   +-input_scan_list=
              | |   | +-GraphNodeScan
              | |   |   +-column_list=[$element_table.n#1]
              | |   |   +-label_expr=
              | |   |   | +-GraphLabel(parse_location=19-25, label=aml.Person)
              | |   |   +-target_element_table_list=[aml.Person]
              | |   +-head=$element_table.n#1
              | |   +-tail=$element_table.n#1
              | +-input_scan=
              |   +-SingleRowScan
              +-ProjectScan
              | +-column_list=$graph_table.[n#3, cnt#2]
              | +-input_scan=
              |   +-AggregateScan
              |     +-column_list=$graph_table.[n#3, cnt#2]
              |     +-input_scan=
